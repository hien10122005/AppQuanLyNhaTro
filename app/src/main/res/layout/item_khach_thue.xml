<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_glass_card_ripple"
    android:clickable="true"
    android:focusable="true"
    android:padding="16dp">

    <!-- Avatar Section -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvAvatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:cardBackgroundColor="#10FFFFFF"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp"
            android:src="@android:drawable/ic_menu_myplaces"
            app:tint="@color/primary_blue" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvItemHoTen"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:text="Nguyễn Văn A"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/tvTrangThai"
        app:layout_constraintStart_toEndOf="@id/cvAvatar"
        app:layout_constraintTop_toTopOf="@id/cvAvatar" />

    <TextView
        android:id="@+id/tvItemSoDienThoai"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="0901 234 567"
        android:textColor="#80FFFFFF"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="@id/tvItemHoTen"
        app:layout_constraintStart_toStartOf="@id/tvItemHoTen"
        app:layout_constraintTop_toBottomOf="@id/tvItemHoTen" />

    <!-- Status Chip -->
    <TextView
        android:id="@+id/tvTrangThai"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_card"
        android:backgroundTint="#15007AFF"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="Đang thuê"
        android:textColor="@color/primary_blue"
        android:textSize="11sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Divider -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="16dp"
        android:background="#0DFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/cvAvatar" />

    <!-- Bottom info -->
    <TextView
        android:id="@+id/tvRoomLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Phòng đang thuê:"
        android:textColor="#60FFFFFF"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <TextView
        android:id="@+id/tvItemPhong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:text="P.101"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBaseline_toBaselineOf="@id/tvRoomLabel"
        app:layout_constraintStart_toEndOf="@id/tvRoomLabel" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_media_play"
        app:layout_constraintBottom_toBottomOf="@id/tvRoomLabel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvRoomLabel"
        app:tint="#40FFFFFF" />

</androidx.constraintlayout.widget.ConstraintLayout>
