<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_dark">

    <!-- AppBarLayout với fix lỗi đổi màu khi cuộn -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_deep_dark"
        app:liftOnScroll="false"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_glass_circle_white"
                android:backgroundTint="#15FFFFFF"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chốt Điện Nước"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:text="Nhập chỉ số hàng tháng cho từng phòng để tính hóa đơn."
                android:textColor="#80FFFFFF"
                android:textSize="14sp" />

            <!-- CARD 1: CHỌN PHÒNG -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHÒNG CẦN CHỐT"
                        android:textColor="@color/primary_blue"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1" />

                    <Spinner
                        android:id="@+id/spinnerPhong"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="16dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#15FFFFFF"
                        android:paddingHorizontal="12dp"
                        android:popupBackground="@color/bg_deep_dark" />

                    <TextView
                        android:id="@+id/tvThangNam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tháng --/----"
                        android:textColor="#60FFFFFF"
                        android:textSize="13sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2: CHỈ SỐ ĐIỆN -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_electric_water"
                            app:tint="@color/primary_blue" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="ĐIỆN (KWH)"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDienChiSoCu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Chỉ số cũ: --"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etDienMoi"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#15FFFFFF"
                        android:hint="Nhập chỉ số mới..."
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:importantForAutofill="no" />

                    <TextView
                        android:id="@+id/tvDienTieuThu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tiêu thụ: -- kWh"
                        android:textColor="@color/success_green"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 3: CHỈ SỐ NƯỚC -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:cardBackgroundColor="@color/glass_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_electric_water"
                            app:tint="@color/success_green" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="NƯỚC (M³)"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvNuocChiSoCu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Chỉ số cũ: --"
                        android:textColor="#80FFFFFF"
                        android:textSize="14sp" />

                    <EditText
                        android:id="@+id/etNuocMoi"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#15FFFFFF"
                        android:hint="Nhập chỉ số mới..."
                        android:inputType="numberDecimal"
                        android:paddingHorizontal="16dp"
                        android:textColor="@color/white"
                        android:textColorHint="#40FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:importantForAutofill="no" />

                    <TextView
                        android:id="@+id/tvNuocTieuThu"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="Tiêu thụ: -- m³"
                        android:textColor="@color/success_green"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLuuChiSo"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="LƯU CHỈ SỐ"
                android:textColor="@color/white"
                android:textStyle="bold"
                android:textSize="16sp"
                app:cornerRadius="20dp"
                app:backgroundTint="@color/primary_blue"
                app:icon="@drawable/ic_bolt"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
