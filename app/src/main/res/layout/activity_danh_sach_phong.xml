<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_dark">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_deep_dark"
        app:liftOnScroll="false"
        app:elevation="0dp">

        <!-- Top App Bar - Fixed -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:paddingHorizontal="16dp"
            app:layout_scrollFlags="noScroll">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_glass_circle_white"
                android:backgroundTint="#15FFFFFF"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Quản lý Phòng"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="-0.04"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnNotifications"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/notifications_desc"
                android:src="@android:drawable/ic_popup_reminder"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#60FFFFFF" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Sticky Search & Filter Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="12dp"
            android:baselineAligned="false"
            android:background="@color/bg_deep_dark">

            <!-- Search Card -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/clSearch"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_glass_card">

                <ImageView
                    android:id="@+id/ivSearch"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginStart="16dp"
                    android:contentDescription="@string/search_desc"
                    android:src="@android:drawable/ic_menu_search"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#60FFFFFF" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="16dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/search_hint_room"
                    android:inputType="text"
                    android:importantForAutofill="no"
                    android:textColor="@color/white"
                    android:textColorHint="#40FFFFFF"
                    android:textSize="14sp"
                    android:maxLines="1"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/ivSearch" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:paddingBottom="2dp">

                    <TextView
                        android:id="@+id/chipAll"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_primary_button"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Tất cả"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/chipTrong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#20FFFFFF"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Trống"
                        android:textColor="#A0FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipDangThue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#20FFFFFF"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Đang thuê"
                        android:textColor="#A0FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/chipBaoTri"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_glass_card"
                        android:backgroundTint="#20FFFFFF"
                        android:paddingHorizontal="20dp"
                        android:paddingVertical="8dp"
                        android:text="Bảo trì"
                        android:textColor="#A0FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main List Container -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDanhSachPhong"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="100dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        tools:listitem="@layout/item_phong" />

    <!-- Action: FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btnThemPhong"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="100dp"
        android:contentDescription="@string/add_room_desc"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/primary_blue"
        app:tint="@color/white"
        app:elevation="8dp"
        app:fabSize="normal" />

    <!-- ===== BOTTOM: BottomNavigationView ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="@color/bottom_nav_icon_selector"
        app:itemTextColor="@color/bottom_nav_text_selector"
        app:itemTextAppearanceActive="@style/BottomNavLabel"
        app:itemTextAppearanceInactive="@style/BottomNavLabel"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/bottom_nav_menu" />


</androidx.coordinatorlayout.widget.CoordinatorLayout>
