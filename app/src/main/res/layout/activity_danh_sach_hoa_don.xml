<?xml version="1.0" encoding="utf-8"?>
<!--
    DANH SÁCH HÓA ĐƠN - activity_danh_sach_hoa_don.xml
    Phong cách H-TECH: Deep Dark + Glassmorphism + Electric Blue

    Cấu trúc:
    ConstraintLayout (root, bg đen)
    ├── LinearLayout Header (Tiêu đề + Lọc tháng)
    ├── LinearLayout Filter Chips (Tất cả / Chưa thu / Đã thu / Quá hạn)
    ├── RecyclerView (danh sách hóa đơn - tự động từ Adapter)
    └── BottomNavigationView (thanh tab dưới)
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_dark">

    <!-- ===== HEADER: Tiêu đề + Bộ lọc tháng ===== -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Dòng 1: Nút Back + Tiêu đề + Nút Thêm mới -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Nút quay lại -->
            <TextView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_glass_card"
                android:gravity="center"
                android:text="‹"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Tiêu đề màn hình -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_weight="1"
                android:text="Hóa Đơn"
                android:textColor="#FFFFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <!-- Nút lập hóa đơn mới -->
            <TextView
                android:id="@+id/btnLapHoaDon"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="+ Lập HĐ"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Dòng 2: Bộ lọc tháng (Tháng trước / Tháng này / Tháng sau) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_glass_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="4dp">

            <!-- Nút: Tháng trước -->
            <TextView
                android:id="@+id/btnThangTruoc"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="‹"
                android:textColor="@color/primary_blue"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Hiển thị tháng/năm đang xem -->
            <TextView
                android:id="@+id/tvThangNam"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Tháng 4 / 2026"
                android:textColor="#FFFFFFFF"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Nút: Tháng sau -->
            <TextView
                android:id="@+id/btnThangSau"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="›"
                android:textColor="@color/primary_blue"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== FILTER CHIPS: Lọc theo trạng thái hóa đơn ===== -->
    <HorizontalScrollView
        android:id="@+id/scrollFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="10dp">

            <!-- Chip: Tất cả -->
            <TextView
                android:id="@+id/chipTatCa"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_primary_button"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="Tất cả"
                android:textColor="#FFFFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Chip: Chưa thu -->
            <TextView
                android:id="@+id/chipChuaThu"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_chip_red"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="Chưa thu"
                android:textColor="@color/warning_red"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Chip: Đã thu -->
            <TextView
                android:id="@+id/chipDaThu"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginRight="8dp"
                android:background="@drawable/bg_chip_green"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="Đã thu"
                android:textColor="@color/success_green"
                android:textSize="12sp"
                android:textStyle="bold" />

            <!-- Chip: Quá hạn -->
            <TextView
                android:id="@+id/chipQuaHan"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_chip_orange"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:text="Quá hạn"
                android:textColor="#FF9500"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== THỐNG KÊ NHANH: 3 số tóm tắt tháng này ===== -->
    <LinearLayout
        android:id="@+id/layoutThongKe"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:background="@drawable/bg_hero_card"
        android:orientation="horizontal"
        android:padding="14dp"
        app:layout_constraintTop_toBottomOf="@id/scrollFilter"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Cột: Tổng phải thu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Phải Thu"
                android:textColor="#808BAA"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvTongPhaiThu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--"
                android:textColor="#FFFFFFFF"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:background="#1AFFFFFF" />

        <!-- Cột: Đã thu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đã Thu"
                android:textColor="#808BAA"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvSummaryDaThu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--"
                android:textColor="@color/success_green"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:background="#1AFFFFFF" />

        <!-- Cột: Còn nợ -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Còn Nợ"
                android:textColor="#808BAA"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/tvSummaryChuaThu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="--"
                android:textColor="@color/warning_red"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== RECYCLERVIEW: Danh sách hóa đơn ===== -->
    <!--
        RecyclerView là View đặc biệt để hiển thị danh sách cuộn.
        Nó sẽ tự động tái sử dụng các item để tiết kiệm bộ nhớ.
        Dữ liệu thật sẽ được đưa vào từ Java qua Adapter.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerHoaDon"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutThongKe"
        app:layout_constraintBottom_toTopOf="@id/bottom_navigation"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/bg_bottom_nav"
        app:itemIconTint="@color/bottom_nav_icon_selector"
        app:itemTextColor="@color/bottom_nav_text_selector"
        app:itemTextAppearanceActive="@style/BottomNavLabel"
        app:itemTextAppearanceInactive="@style/BottomNavLabel"
        app:labelVisibilityMode="labeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:menu="@menu/bottom_nav_menu" />


</androidx.constraintlayout.widget.ConstraintLayout>
