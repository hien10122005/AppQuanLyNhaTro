<?xml version="1.0" encoding="utf-8"?>
<!-- Background cho Hero Card doanh thu: glass + viền xanh lam nhẹ -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Nền glass tối hơn một chút so với card thông thường -->
    <solid android:color="#1A1C2E" />
    <!-- Viền 1px màu xanh lam mờ để tạo "blue glow" -->
    <stroke
        android:width="1dp"
        android:color="#33007AFF" />
    <corners android:radius="24dp" />
</shape>
